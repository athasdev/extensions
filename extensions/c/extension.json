{
  "$schema": "https://athas.dev/schemas/extension.json",
  "id": "athas.c",
  "name": "C",
  "displayName": "C",
  "version": "1.0.0",
  "description": "C language support with LSP",
  "publisher": "Athas",
  "categories": [
    "Language"
  ],
  "languages": [
    {
      "id": "c",
      "extensions": [
        ".c",
        ".h"
      ],
      "aliases": [
        "C"
      ]
    }
  ],
  "capabilities": {
    "lsp": {
      "name": "clangd",
      "runtime": "binary",
      "args": [
        "--background-index"
      ]
    }
  }
}
