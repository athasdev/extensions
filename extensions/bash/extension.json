{
  "$schema": "https://athas.dev/schemas/extension.json",
  "id": "athas.bash",
  "name": "Bash",
  "displayName": "Bash",
  "version": "1.0.0",
  "description": "Bash/Shell script support with LSP",
  "publisher": "Athas",
  "categories": [
    "Language"
  ],
  "languages": [
    {
      "id": "bash",
      "extensions": [
        ".sh",
        ".bash",
        ".zsh"
      ],
      "aliases": [
        "Bash",
        "Shell",
        "sh"
      ],
      "filenames": [
        ".bashrc",
        ".zshrc",
        ".bash_profile",
        ".profile"
      ]
    }
  ],
  "capabilities": {
    "lsp": {
      "name": "bash-language-server",
      "runtime": "bun",
      "package": "bash-language-server",
      "args": [
        "start"
      ]
    }
  }
}
