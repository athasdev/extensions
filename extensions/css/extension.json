{
  "$schema": "https://athas.dev/schemas/extension.json",
  "id": "athas.css",
  "name": "CSS",
  "displayName": "CSS",
  "version": "1.0.0",
  "description": "CSS language support with LSP and formatting",
  "publisher": "Athas",
  "categories": [
    "Language"
  ],
  "languages": [
    {
      "id": "css",
      "extensions": [
        ".css",
        ".scss",
        ".sass",
        ".less"
      ],
      "aliases": [
        "CSS"
      ]
    }
  ],
  "capabilities": {
    "lsp": {
      "name": "vscode-css-language-server",
      "runtime": "bun",
      "package": "vscode-langservers-extracted",
      "args": [
        "--stdio"
      ]
    },
    "formatter": {
      "name": "prettier",
      "runtime": "bun",
      "package": "prettier",
      "args": [
        "--stdin-filepath",
        "${file}"
      ]
    }
  }
}
