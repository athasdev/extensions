{
  "$schema": "https://athas.dev/schemas/extension.json",
  "id": "athas.json",
  "name": "JSON",
  "displayName": "JSON",
  "version": "1.0.0",
  "description": "JSON language support with LSP and formatting",
  "publisher": "Athas",
  "categories": [
    "Language"
  ],
  "languages": [
    {
      "id": "json",
      "extensions": [
        ".json",
        ".jsonc"
      ],
      "aliases": [
        "JSON"
      ]
    }
  ],
  "capabilities": {
    "lsp": {
      "name": "vscode-json-language-server",
      "runtime": "bun",
      "package": "vscode-langservers-extracted",
      "args": [
        "--stdio"
      ]
    },
    "formatter": {
      "name": "prettier",
      "runtime": "bun",
      "package": "prettier",
      "args": [
        "--stdin-filepath",
        "${file}"
      ]
    }
  }
}
